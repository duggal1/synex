generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  clerkId       String?   @unique
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  apiKey        String    @unique @default(uuid())

  // Subscription and billing
  subscriptionId     String?
  subscriptionStatus SubscriptionStatus @default(FREE)
  usageLimit         Int                @default(10) // Number of projects allowed

  // Resources
  projects    Project[]
  domains     Domain[]
  deployments Deployment[]
  analytics   Analytics[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionStatus])
}

model Project {
  id           String        @id @default(cuid())
  name         String
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  envVariables EnvVariable[]

  // Project configuration
  framework     Framework @default(NEXTJS)
  nodeVersion   String    @default("18.x")
  buildCommand  String    @default("npm run build")
  startCommand  String    @default("npm start")
  rootDirectory String    @default("./")

  // Deployment and domains
  domains      Domain[]
  deployments  Deployment[]
  environments Environment[]

  // Build settings
  buildCache       Boolean @default(true)
  automaticDeploys Boolean @default(true)

  // Performance
  cdn       Boolean     @default(true)
  analytics Analytics[]

  // Status and metadata
  status             ProjectStatus @default(ACTIVE)
  optimizationStatus String?
  lastOptimized      DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  productionDeploymentId String?

  edgeFunctions      EdgeFunction[]
  storage            ProjectStorage[]
  config             ProjectConfig?
  files              ProjectFile[]
  cacheHeaders       Json?
  PerformanceMetrics PerformanceMetrics[]

  @@index([userId])
  @@index([status])
}

model Domain {
  id        String  @id @default(cuid())
  domain    String  @unique
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  // Domain configuration
  type     DomainType @default(SUBDOMAIN)
  ssl      Boolean    @default(true)
  verified Boolean    @default(false)

  // DNS records
  dnsRecords DnsRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}

model Deployment {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  // Deployment details
  buildCommand  String
  nodeVersion   String
  version       String
  commitHash    String?
  branch        String      @default("main")
  environment   Environment @relation(fields: [environmentId], references: [id])
  environmentId String

  // Build information
  buildLogs Json
  buildTime Int              @default(0) // in seconds
  status    DeploymentStatus @default(QUEUED)

  // Container info
  containerId   String?
  containerPort Int?

  // Metrics
  memory Int   @default(0) // in MB
  cpu    Float @default(0) // percentage

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  metrics   Metrics[]
  analytics Analytics[]

  url String?

  logs DeploymentLog[]

  @@index([projectId])
  @@index([status])
}

model Environment {
  id        String  @id @default(cuid())
  name      String // e.g., "production", "staging"
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  // Environment configuration
  variables   EnvVariable[]
  deployments Deployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([projectId, name])
}

model EnvVariable {
  id            String      @id @default(cuid())
  key           String
  value         String
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  @@unique([environmentId, key])
}

model DnsRecord {
  id       String @id @default(cuid())
  domainId String
  domain   Domain @relation(fields: [domainId], references: [id])
  type     String // A, CNAME, TXT, etc.
  name     String
  content  String
  ttl      Int    @default(3600)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Analytics {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id])
  deploymentId String?
  deployment   Deployment? @relation(fields: [deploymentId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])

  // Analytics data
  type      String // 'REQUEST', 'RESPONSE', 'BUILD', 'RESOURCE', 'REALTIME'
  metrics   Json
  timestamp DateTime @default(now())

  @@index([projectId])
  @@index([deploymentId])
  @@index([userId])
  @@index([timestamp])
  @@index([type])
}

model EdgeFunction {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  name      String
  route     String
  runtime   String // 'nodejs' | 'python' | 'rust'
  memory    Int     @default(128)
  timeout   Int     @default(5000)
  version   String
  code      String  @db.Text

  // Metrics
  metrics EdgeFunctionMetrics[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([projectId])
}

model EdgeFunctionMetrics {
  id         String       @id @default(cuid())
  functionId String
  function   EdgeFunction @relation(fields: [functionId], references: [id])

  // Metrics
  invocations Int   @default(0)
  errors      Int   @default(0)
  latency     Float @default(0)
  cpu         Float @default(0)
  memory      Int   @default(0)

  timestamp DateTime @default(now())

  @@index([functionId])
  @@index([timestamp])
}

model ProjectConfig {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id])

  // Rendering configuration
  renderingConfig Json
  framework       Framework
  strategy        RenderingStrategy @default(STATIC)

  // Optimization status
  optimizationStatus OptimizationStatus @default(PENDING)
  lastOptimized      DateTime?

  // File configurations
  configFiles ProjectFile[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  performanceConfig Json?
  cacheConfig       Json?
  cdnConfig         Json?
  autoScalingConfig Json?

  @@index([projectId])
}

model ProjectFile {
  id        String         @id @default(cuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id])
  configId  String?
  config    ProjectConfig? @relation(fields: [configId], references: [id])

  filename String
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, filename])
  @@index([projectId])
  @@index([configId])
}

enum SubscriptionStatus {
  FREE
  PRO
  ENTERPRISE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  DEPLOYING
  DEPLOYED
  FAILED
  CANCELLED
}

enum Framework {
  NEXTJS
  REMIX
  ASTRO
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

//storage for project builds
model ProjectStorage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  fileName  String   @unique
  hash      String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model Metrics {
  id           String     @id @default(cuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id])

  // Container metrics
  cpu          Float @default(0)
  memory       Int   @default(0)
  requests     Int   @default(0)
  responseTime Float @default(0)

  // Additional metrics
  errorRate  Float @default(0)
  throughput Int   @default(0)

  timestamp DateTime @default(now())

  @@index([deploymentId])
  @@index([timestamp])
}

model DeploymentLog {
  id           String     @id @default(cuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
  level        String // 'INFO', 'WARN', 'ERROR'
  message      String
  timestamp    DateTime   @default(now())

  @@index([deploymentId])
  @@index([level])
  @@index([timestamp])
}

enum OptimizationStatus {
  PENDING
  OPTIMIZING
  OPTIMIZED
  FAILED
}

enum RenderingStrategy {
  STATIC
  SSR
  ISR
  HYBRID
}

// Add this model for performance metrics
model PerformanceMetrics {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  metrics   Json
  timestamp DateTime @default(now())

  @@index([projectId])
  @@index([timestamp])
}
