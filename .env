# Redis
REDIS_URL=redis://redis:6379

# Environment
NODE_ENV=development

# Domain & DNS
ROOT_DOMAIN=yourdomain.com
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_ZONE_ID=your_zone_id

# Storage (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=****

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=app_network
CONTAINER_REGISTRY=****

# Build Configuration
BUILD_OUTPUT_DIR=/app/builds
BUILD_CACHE_DIR=/app/cache
MAX_BUILD_DURATION=600 # seconds
MAX_CONCURRENT_BUILDS=5

# Resource Limits
DEFAULT_CONTAINER_MEMORY=1024 # MB
DEFAULT_CONTAINER_CPU=1000 # millicores
MAX_PROJECTS_FREE=3
MAX_PROJECTS_PRO=20

# Performance
CACHE_TTL=3600
EDGE_CACHE_TTL=86400
CDN_ENABLED=true
SSL_ENABLED=true

# Monitoring
SENTRY_DSN=****
LOG_LEVEL=info

# API Rate Limiting
RATE_LIMIT_WINDOW=60000 # 1 minute
RATE_LIMIT_MAX=100 # requests per window

# Ports
PORT=3000
NGINX_PORT=80
NGINX_SSL_PORT=443

# Node
NODE_ENV=production

#logger
LOG_LEVEL=debug
LOGTAIL_SOURCE_TOKEN=your_token_here  # Only needed in production

BASE_DOMAIN=yourdomain.com
LOAD_BALANCER_IP=your.load.balancer.ip